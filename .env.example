# ═══════════════════════════════════════════════════════════════════
# KaggleMate 配置文件 / Configuration
# ═══════════════════════════════════════════════════════════════════
#
# 复制此文件为 .env:  cp .env.example .env
# 然后填入你的真实 API 密钥。

# ── DeepSeek API (必需 / Required) ──
# 获取密钥: https://platform.deepseek.com/api_keys
# 免费注册，按量付费。V4 Pro ~$0.44/百万token, V4 Flash ~$0.14/百万token
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── DeepSeek Flash 模型 (可选 / Optional) ──
# 用于批量任务（便宜 3 倍、速度快），如 Notebook 批量总结
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash

# ── Kaggle API (必需 / Required) ──
# 方式一（推荐）: 在网页上生成 kaggle.json，放到 ~/.kaggle/ 目录
#   1. 打开 https://www.kaggle.com/settings/account
#   2. 滚动到 API 部分 → Create New Token → 下载 kaggle.json
#   3. mkdir -p ~/.kaggle && mv ~/Downloads/kaggle.json ~/.kaggle/
#   4. chmod 600 ~/.kaggle/kaggle.json
#
# 方式二: 在这里直接填写（不推荐——密钥会留在本地 .env 文件中）
# KAGGLE_USERNAME=your-kaggle-username
# KAGGLE_KEY=your-kaggle-api-key
