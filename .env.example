# ═══════════════════════════════════════════════════════════════════
# KaggleMate 配置文件 / Configuration
# ═══════════════════════════════════════════════════════════════════
#
# 复制此文件为 .env:  cp .env.example .env
# 然后填入你的真实 API 密钥。

# ── LLM Provider / 模型提供商 (必需 / Required) ──
# KaggleMate 支持任何 OpenAI 兼容的 API。
# KaggleMate supports any OpenAI-compatible API.
#
# === 快速配置：选一个预设 / Quick config: pick a preset ===
#
# DeepSeek (默认):
#   LLM_PROVIDER=deepseek
#   LLM_API_KEY=sk-your-key-here
#   获取密钥: https://platform.deepseek.com/api_keys
#   定价: V4 Pro ~$0.44/百万token, V4 Flash ~$0.14/百万token
#
# OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-your-key-here
#   获取密钥: https://platform.openai.com/api-keys
#
# 自定义 (Ollama / vLLM / Anthropic 代理 / Groq / ...):
#   LLM_PROVIDER=custom
#   LLM_API_KEY=your-key-or-ollama
#   LLM_BASE_URL=http://localhost:11434/v1  (Ollama)
#   LLM_MODEL=qwen3:latest                 (Ollama)
#   LLM_FLASH_MODEL=qwen3:latest           (本地模型通常只有一个)

LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.deepseek.com     # 预设会自动填充 / auto-filled by preset
# LLM_MODEL=deepseek-v4-pro                 # 预设会自动填充 / auto-filled by preset
# LLM_FLASH_MODEL=deepseek-v4-flash         # 可选，用于批量任务省钱 / optional cheaper model

# ── 兼容旧版配置（仍可用，但不推荐） ──
# 如果你设置了 DEEPSEEK_API_KEY，LLM_PROVIDER 会自动设为 deepseek
# DEEPSEEK_API_KEY=sk-xxx

# ── Kaggle API (必需 / Required) ──
# 方式一（推荐）: 在网页上生成 kaggle.json，放到 ~/.kaggle/ 目录
#   1. 打开 https://www.kaggle.com/settings/account
#   2. 滚动到 API 部分 → Create New Token → 下载 kaggle.json
#   3. mkdir -p ~/.kaggle && mv ~/Downloads/kaggle.json ~/.kaggle/
#   4. chmod 600 ~/.kaggle/kaggle.json
#
# 方式二: 在这里直接填写（不推荐——密钥会留在本地 .env 文件中）
# KAGGLE_USERNAME=your-kaggle-username
# KAGGLE_KEY=your-kaggle-api-key
